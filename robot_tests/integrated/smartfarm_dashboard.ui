  </property>
  <property name="styleSheet">
   <string notr="true">
    QMainWindow { background-color: #f5f7f9; }
    QLabel#lbl_title { font-size: 34px; font-weight: 800; color: #111827; }
    QGroupBox { background-color: #ffffff; border: 1px solid #d9e1e8; border-radius: 14px; margin-top: 26px; font-size: 16px; font-weight: 700; color: #116b25; }
    QGroupBox::title { subcontrol-origin: margin; subcontrol-position: top left; left: 18px; padding: 0px 8px; }
    QLabel { font-size: 14px; color: #1f2937; }
    QLabel[value=&quot;true&quot;] { font-size: 15px; font-weight: 700; color: #0b6b20; }
    QPushButton { background-color: #ffffff; border: 1px solid #cfd8df; border-radius: 10px; font-size: 15px; font-weight: 700; padding: 8px; }
    QPushButton:hover { background-color: #f0f8f2; border: 1px solid #159447; }
    QPushButton#btn_start { background-color: #eaf8ed; color: #0b7a25; border: 1px solid #6fbe7b; }
    QPushButton#btn_stop { background-color: #fff7e6; color: #b36b00; border: 1px solid #f2c15f; }
    QPushButton#btn_shutdown { background-color: #eef2f7; color: #374151; border: 1px solid #bfc8d2; }
    QPushButton#btn_estop { background-color: #fff0f0; color: #d60000; border: 1px solid #ff9b9b; }
    QPushButton#btn_recovery { background-color: #eef8ff; color: #075985; border: 1px solid #7dd3fc; }
    QPushButton#btn_home, QPushButton#btn_tray_check, QPushButton#btn_tray1_move, QPushButton#btn_tray2_move, QPushButton#btn_tray3_move, QPushButton#btn_tray4_move { color: #0b6b20; }
    QPushButton#btn_press_pickup, QPushButton#btn_press_putdown, QPushButton#btn_shovel_pickup, QPushButton#btn_shovel_putdown { font-size: 13px; font-weight: 700; color: #1f2937; }
    QPushButton#btn_refill, QPushButton#btn_remove_soil, QPushButton#btn_remove_obstacle, QPushButton#btn_plant { color: #6b3b10; }
    QComboBox { background-color: #ffffff; border: 1px solid #cfd8df; border-radius: 8px; padding: 6px; font-size: 14px; }
    QSlider::groove:horizontal { height: 8px; background: #e5e7eb; border-radius: 4px; }
    QSlider::handle:horizontal { background: #159447; width: 16px; height: 16px; margin: -5px 0; border-radius: 8px; }
    QTextEdit { background-color: #ffffff; border: 1px solid #d9e1e8; border-radius: 10px; font-family: Consolas, monospace; font-size: 14px; }
    QTableWidget { background-color: #ffffff; border: 1px solid #e0e6ec; border-radius: 8px; gridline-color: #e5e7eb; font-size: 13px; }
    QHeaderView::section { background-color: #eef8f0; color: #116b25; font-weight: 700; border: 1px solid #d9e1e8; padding: 4px; }
   </string>
  </property>
