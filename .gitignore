
  # =========================
  # Project test / temp files
  # =========================
  test.txt
  *.tmp
  *.bak
  *.orig
  *.rej

  # =========================
  # ROS2 / colcon build outputs
  # =========================
  build/
  install/
  log/
  ws_cobot1/build/
  ws_cobot1/install/
  ws_cobot1/log/
  ws_dsr/build/
  ws_dsr/install/
  ws_dsr/log/

  # =========================
  # ROS2 bag / recording files
  # 큰 파일이 되기 쉬우므로 기본 무시
  # =========================
  rosbag2_*/
  *.bag
  *.db3
  *.mcap

  # =========================
  # Python cache / test / coverage
  # =========================
  __pycache__/
  *.py[cod]
  *$py.class
  .pytest_cache/
  .coverage
  htmlcov/

  # =========================
  # Python virtual environments
  # =========================
  .venv/
  venv/
  env/
  ENV/

  # =========================
  # Python package metadata
  # =========================
  *.egg-info/
  .eggs/
  dist/

  # =========================
  # VS Code local workspace/cache
  # =========================
  .vscode/
  **/.vscode/
  *.vc.db
  *.vc.db-shm
  *.vc.db-wal
  browse.vc.db
  browse.vc.db-shm
  browse.vc.db-wal

  # =========================
  # JetBrains IDE
  # =========================
  .idea/

  # =========================
  # C/C++ build artifacts
  # =========================
  *.o
  *.a
  *.so
  *.dll
  *.dylib
  *.exe

  # =========================
  # CMake
  # =========================
  CMakeFiles/
  CMakeCache.txt
  cmake_install.cmake
  Makefile

  # =========================
  # Project-specific generated logs
  # =========================
  DartPlatform/Logs/

  # =========================
  # OS files
  # =========================
  .DS_Store
  Thumbs.db

  # =========================
  # Editor temporary files
  # =========================
  *.swp
  *.swo
  *~

